exports[`snapshot tests > classes.no 1`] = `
"class Animal {
  constructor(name) {
    this.name = name;
  }

  speak() {
    return console.log(\`I am \${this.name}\`);
  }
}
class Dog extends Animal {
  speak() {
    return console.log(\`\${this.name} barks!\`);
  }
}"
`;

exports[`snapshot tests > control-flow.no 1`] = `
"if (x > 0) {
  console.log("positive");
} else {
  console.log("non-positive");
}
for (let i = 0; i <= 5; i++) {
  console.log(i);
}
for (const item of items) {
  console.log(item);
}
while (count > 0) {
  let count = count - 1;
}
switch (color) {
  case "red":
    console.log("stop");
    break;
  case "green":
    console.log("go");
    break;
  default:
    console.log("unknown");
    break;
}"
`;

