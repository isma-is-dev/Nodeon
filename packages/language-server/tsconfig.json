{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "baseUrl": "../../",
    "paths": {
      "@language/*": ["src/language/*"],
      "@lexer/*": ["src/compiler/lexer/*"],
      "@parser/*": ["src/compiler/parser/*"],
      "@compiler/*": ["src/compiler/*"],
      "@ast/*": ["src/compiler/ast/*"],
      "@src/*": ["src/*"]
    },
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
  },
  "include": ["src/**/*"]
}
