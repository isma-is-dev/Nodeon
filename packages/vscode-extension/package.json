{
  "name": "nodeon-vscode-extension",
  "displayName": "Nodeon",
  "description": "Syntax highlighting y LSP client para Nodeon (.no)",
  "version": "0.0.1",
  "publisher": "nodeon",
  "repository": {
    "type": "git",
    "url": "https://github.com/isma-is-dev/Nodeon.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "license": "MIT",
  "main": "dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "languages": [
      {
        "id": "nodeon",
        "aliases": [
          "Nodeon",
          "nodeon"
        ],
        "extensions": [
          ".no"
        ],
        "icon": {
          "light": "./assets/no-file.svg",
          "dark": "./assets/no-file.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nodeon",
        "scopeName": "source.nodeon",
        "path": "./syntaxes/nodeon.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "nodeon",
        "scopes": {
          "function": ["entity.name.function.nodeon"],
          "function.declaration": ["entity.name.function.declaration.nodeon"],
          "function.defaultLibrary": ["support.function.builtin.nodeon"],
          "method": ["entity.name.function.member.nodeon"],
          "method.declaration": ["entity.name.function.member.nodeon"],
          "variable": ["variable.other.readwrite.nodeon"],
          "variable.readonly": ["variable.other.constant.nodeon"],
          "variable.declaration": ["variable.other.readwrite.nodeon"],
          "parameter": ["variable.parameter.nodeon"],
          "parameter.declaration": ["variable.parameter.nodeon"],
          "property": ["variable.other.property.nodeon"],
          "property.declaration": ["variable.other.property.nodeon"],
          "class": ["entity.name.type.class.nodeon"],
          "class.declaration": ["entity.name.type.class.nodeon"],
          "enum": ["entity.name.type.enum.nodeon"],
          "enumMember": ["variable.other.enummember.nodeon"],
          "interface": ["entity.name.type.interface.nodeon"],
          "type": ["entity.name.type.nodeon"],
          "namespace": ["entity.name.namespace.nodeon"]
        }
      }
    ],
    "configurationDefaults": {
      "editor.semanticHighlighting.enabled": true,
      "[nodeon]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs": "active",
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.formatOnType": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0",
    "vscode": "^1.1.37"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
