{
  "name": "nodeon-vscode-extension",
  "displayName": "Nodeon",
  "description": "Syntax highlighting y LSP client para Nodeon (.no)",
  "version": "0.0.1",
  "publisher": "nodeon",
  "repository": {
    "type": "git",
    "url": "https://github.com/isma-is-dev/Nodeon.git"
  },
  "engines": {
    "vscode": "^1.84.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "license": "MIT",
  "main": "dist/extension.js",
  "activationEvents": [
    "onLanguage:nodeon"
  ],
  "contributes": {
    "languages": [
      {
        "id": "nodeon",
        "aliases": [
          "Nodeon",
          "nodeon"
        ],
        "extensions": [
          ".no"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nodeon",
        "scopeName": "source.nodeon",
        "path": "./syntaxes/nodeon.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "nodeon-icons",
        "label": "Nodeon Icons",
        "path": "./icon-theme.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build --production",
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.25",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.3",
    "vsce": "^2.15.0",
    "vscode": "^1.1.37"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
