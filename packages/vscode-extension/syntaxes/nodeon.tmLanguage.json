{
  "scopeName": "source.nodeon",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#type-annotation-block" },
    { "include": "#private-field" },
    { "include": "#keywords" },
    { "include": "#type-standalone" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#function-declaration" },
    { "include": "#function-call" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.nodeon", "match": "//.*$" },
        { "name": "comment.block.nodeon", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nodeon",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.nodeon", "match": "\\\\." },
            {
              "name": "meta.embedded.expression.nodeon",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.nodeon" } },
              "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.nodeon" } },
              "patterns": [{ "include": "#expressions" }]
            }
          ]
        },
        {
          "name": "string.quoted.single.nodeon",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.nodeon", "match": "\\\\." }
          ]
        },
        {
          "name": "string.quoted.template.nodeon",
          "begin": "`",
          "end": "`",
          "patterns": [
            { "name": "constant.character.escape.nodeon", "match": "\\\\." },
            {
              "name": "meta.embedded.expression.nodeon",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.nodeon" } },
              "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.nodeon" } },
              "patterns": [{ "include": "#expressions" }]
            }
          ]
        }
      ]
    },
    "private-field": {
      "patterns": [
        {
          "name": "variable.other.private.nodeon",
          "match": "#[_$a-zA-Z][_$a-zA-Z0-9]*"
        }
      ]
    },
    "type-annotation-block": {
      "comment": "Matches : followed by type expressions (primitives, user types, unions, arrays)",
      "patterns": [
        {
          "comment": "Full type annotation: : string | number, : MyType[], : Promise<T>",
          "begin": "(?<=\\)|[_$a-zA-Z0-9])\\s*(:)\\s*(?=[a-zA-Z])",
          "end": "(?=[=){,;]|$)",
          "beginCaptures": {
            "1": { "name": "keyword.operator.type.annotation.nodeon" }
          },
          "patterns": [
            { "include": "#type-expression" }
          ]
        }
      ]
    },
    "type-expression": {
      "patterns": [
        {
          "comment": "Primitive types: string, number, boolean, void, any, never, null, undefined",
          "name": "support.type.primitive.nodeon",
          "match": "\\b(string|number|boolean|void|any|never|null|undefined|bigint|symbol)\\b"
        },
        {
          "comment": "User-defined types (PascalCase): MyClass, Promise, Array, Map",
          "name": "entity.name.type.nodeon",
          "match": "\\b([A-Z][_$a-zA-Z0-9]*)\\b"
        },
        {
          "comment": "Union/intersection pipe",
          "name": "keyword.operator.type.union.nodeon",
          "match": "[|&]"
        },
        {
          "comment": "Array bracket notation",
          "name": "punctuation.bracket.type.nodeon",
          "match": "\\[\\]"
        },
        {
          "comment": "Generic angle brackets",
          "name": "punctuation.bracket.angle.nodeon",
          "match": "[<>]"
        },
        {
          "comment": "Comma separator in generics",
          "name": "punctuation.separator.comma.nodeon",
          "match": ","
        }
      ]
    },
    "type-standalone": {
      "comment": "Builtin type names used standalone (not after colon), e.g. in generics or as expressions",
      "patterns": [
        {
          "name": "support.type.primitive.nodeon",
          "match": "(?<=<|,\\s|\\|\\s|&\\s)\\b(string|number|boolean|void|any|never)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nodeon",
          "match": "\\b(if|else|for|in|of|while|do|return|break|continue|switch|case|default|try|catch|finally|throw|yield|debugger|match)\\b"
        },
        {
          "name": "keyword.declaration.nodeon",
          "match": "\\b(fn|async|class|extends|import|export|from|enum|interface)\\b"
        },
        {
          "name": "storage.type.nodeon",
          "match": "\\b(const|let|var)\\b"
        },
        {
          "name": "keyword.operator.nodeon",
          "match": "\\b(new|typeof|instanceof|void|delete|await|as)\\b"
        },
        {
          "name": "support.function.builtin.nodeon",
          "match": "\\b(print)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.nodeon", "match": "\\b(true|false)\\b" },
        { "name": "constant.language.null.nodeon", "match": "\\b(null|undefined)\\b" },
        { "name": "variable.language.this.nodeon", "match": "\\b(this|super)\\b" }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.nodeon", "match": "\\b0[xX][0-9A-Fa-f]+n?\\b" },
        { "name": "constant.numeric.binary.nodeon", "match": "\\b0[bB][01]+n?\\b" },
        { "name": "constant.numeric.octal.nodeon", "match": "\\b0[oO][0-7]+n?\\b" },
        { "name": "constant.numeric.decimal.nodeon", "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?n?\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.comparison.nodeon", "match": "===|!==|==|!=|<=|>=|<|>" },
        { "name": "keyword.operator.assignment.compound.nodeon", "match": "\\+=|-=|\\*=|/=|%=|\\*\\*=|&&=|\\|\\|=|\\?\\?=" },
        { "name": "keyword.operator.arithmetic.nodeon", "match": "\\+\\+|--|\\*\\*|\\+|-|\\*|/|%" },
        { "name": "keyword.operator.logical.nodeon", "match": "&&|\\|\\||!" },
        { "name": "keyword.operator.nullish.nodeon", "match": "\\?\\?" },
        { "name": "keyword.operator.spread.nodeon", "match": "\\.\\.\\." },
        { "name": "keyword.operator.range.nodeon", "match": "\\.\\." },
        { "name": "keyword.operator.arrow.nodeon", "match": "=>" },
        { "name": "keyword.operator.pipe.nodeon", "match": "\\|>" },
        { "name": "keyword.operator.optional-chaining.nodeon", "match": "\\?\\." }
      ]
    },
    "function-declaration": {
      "comment": "Function declaration: fn name(...)",
      "patterns": [
        {
          "match": "\\b(fn)\\s+([_$a-zA-Z][_$a-zA-Z0-9]*)\\s*(?=[<(])",
          "captures": {
            "1": { "name": "keyword.declaration.nodeon" },
            "2": { "name": "entity.name.function.declaration.nodeon" }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "match": "\\b([_$a-zA-Z][_$a-zA-Z0-9]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.nodeon" }
          }
        }
      ]
    },
    "identifiers": {
      "patterns": [
        { "name": "variable.other.nodeon", "match": "\\b[_$a-zA-Z][_$a-zA-Z0-9]*\\b" }
      ]
    },
    "expressions": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#private-field" },
        { "include": "#keywords" },
        { "include": "#type-standalone" },
        { "include": "#constants" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#function-call" },
        { "include": "#identifiers" }
      ]
    }
  }
}
